{
  "name": "@openprogram/cli",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "openprogram-cli": "dist/index.js"
  },
  "scripts": {
    "build": "esbuild src/index.tsx --bundle --platform=node --target=node20 --format=esm --outfile=dist/index.js --packages=external --jsx=automatic --banner:js=\"#!/usr/bin/env node\\nimport { createRequire } from 'module'; const require = createRequire(import.meta.url);\"",
    "dev": "esbuild src/index.tsx --bundle --platform=node --target=node20 --format=esm --outfile=dist/index.js --packages=external --jsx=automatic --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@alcalzone/ansi-tokenize": "^0.1.3",
    "auto-bind": "^5.0.1",
    "bidi-js": "^1.0.3",
    "chalk": "^5.3.0",
    "cli-boxes": "^3.0.0",
    "code-excerpt": "^4.0.0",
    "emoji-regex": "^10.6.0",
    "figures": "^6.1.0",
    "get-east-asian-width": "^1.5.0",
    "indent-string": "^5.0.0",
    "lodash-es": "^4.18.1",
    "marked": "^15.0.12",
    "marked-terminal": "^7.3.0",
    "react": "^19.0.0",
    "react-reconciler": "^0.33.0",
    "semver": "^7.7.4",
    "signal-exit": "^4.1.0",
    "stack-utils": "^2.0.6",
    "strip-ansi": "^7.2.0",
    "supports-hyperlinks": "^3.2.0",
    "type-fest": "^4.41.0",
    "usehooks-ts": "^3.1.1",
    "wrap-ansi": "^9.0.2",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^20",
    "@types/react": "^19.0.0",
    "@types/react-reconciler": "^0.33.0",
    "@types/semver": "^7.7.1",
    "@types/stack-utils": "^2.0.3",
    "@types/ws": "^8.5.13",
    "@vitest/ui": "^4.1.5",
    "esbuild": "^0.24.0",
    "typescript": "^5.5.4",
    "vitest": "^4.1.5"
  }
}

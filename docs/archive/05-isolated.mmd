%%{init: {'theme': 'base', 'themeVariables': {'primaryColor': '#e8f4fd', 'primaryTextColor': '#1a1a1a', 'primaryBorderColor': '#4a90d9', 'lineColor': '#666'}}}%%
graph TD
    classDef active fill:#4a90d9,stroke:#2c6fad,color:#fff,stroke-width:2px
    classDef dim fill:#f5f5f5,stroke:#ccc,color:#999

    root["🌳 root"]:::dim
    nav["navigate"]:::dim
    obs["observe"]:::dim
    ocr["run_ocr"]:::dim
    det["detect_all"]:::dim
    act["⭐ act (当前)"]:::active
    verify["verify"]:::dim

    root --> nav
    nav --> obs
    nav --> act
    nav --> verify
    obs --> ocr
    obs --> det

    style root stroke-dasharray: 5 5
    style nav stroke-dasharray: 5 5
    style obs stroke-dasharray: 5 5
    style ocr stroke-dasharray: 5 5
    style det stroke-dasharray: 5 5
    style verify stroke-dasharray: 5 5

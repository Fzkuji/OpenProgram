%%{init: {'theme': 'base', 'themeVariables': {'primaryColor': '#e8f4fd', 'primaryTextColor': '#1a1a1a', 'primaryBorderColor': '#4a90d9', 'lineColor': '#666'}}}%%
graph TD
    classDef active fill:#4a90d9,stroke:#2c6fad,color:#fff,stroke-width:2px
    classDef visible fill:#c8e6c9,stroke:#43a047,color:#1a1a1a,stroke-width:2px
    classDef dim fill:#f5f5f5,stroke:#ccc,color:#999

    subgraph tree1["Context Tree A"]
        root1["🌳 root"]:::dim
        nav["navigate"]:::dim
        obs["observe"]:::dim
        act["act"]:::dim
        root1 --> nav
        nav --> obs
        nav --> act
    end

    subgraph tree2["Context Tree B (独立)"]
        root2["🌳 root B"]:::visible
        bg["⭐ background_check"]:::active
        scan["scan_inbox"]:::visible
        root2 --> bg
        bg --> scan
    end

    style tree1 fill:#fafafa,stroke:#ccc,stroke-dasharray: 5 5
    style tree2 fill:#f0fff0,stroke:#43a047

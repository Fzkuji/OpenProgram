{
  "name": "openprogram-desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Electron desktop shell for OpenProgram",
  "main": "main.js",
  "scripts": {
    "dev": "electron .",
    "check:webtabs": "node scripts/check-webtab-navigation.js",
    "check:tab-transfer-store": "node scripts/check-tab-transfer-store.js",
    "icon:build": "bash scripts/build-icon.sh",
    "icon:check": "bash scripts/check-icon.sh",
    "dist": "npm run icon:build && npm run icon:check && electron-builder --dir"
  },
  "devDependencies": {
    "electron": "^37.2.0",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "ai.openprogram.desktop",
    "productName": "OpenProgram",
    "files": [
      "main.js",
      "preload.js",
      "tab-transfer-store.js"
    ],
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "mac": {
      "target": [
        "dir",
        "zip"
      ],
      "icon": "build/icon.icns"
    }
  }
}
